#!/usr/bin/env bash

set -Eeuo pipefail

function main {
  if ! [[ "$(uname)" == "Darwin" ]]; then
    return
  fi

  echo "macos uninstall: reverting the easily-reversible system tweaks..."

  # Reset Wi-Fi DNS back to DHCP-provided servers
  if networksetup -listallnetworkservices | grep -qx "Wi-Fi"; then
    networksetup -setdnsservers Wi-Fi Empty || true
  fi

  # Undo the caps-lock -> control remap (current session)
  hidutil property --set '{"UserKeyMapping":[]}' > /dev/null || true

  # Remove the persistent remap LaunchAgent
  caps_plist="${HOME}/Library/LaunchAgents/com.local.KeyRemapping.plist"
  if [[ -f "${caps_plist}" ]]; then
    launchctl unload "${caps_plist}" 2>/dev/null || true
    rm -f "${caps_plist}"
  fi

  echo "note: 'defaults write' preferences and the computer hostname are NOT auto-reverted."
}

main
