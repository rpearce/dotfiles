#!/usr/bin/env bash

set -Eeuo pipefail

function install_nix {
  if ! command -v nix >/dev/null; then
    echo "nix install: setting up nix..."

    # Pipe (not process-substitution) so pipefail catches a failed download
    # instead of executing a partial/HTML error body.
    if [[ "$(uname)" == "Darwin" ]]; then
      curl -fSL --proto '=https' --tlsv1.2 https://nixos.org/nix/install | sh
    else
      curl -fSL --proto '=https' --tlsv1.2 https://nixos.org/nix/install | sh -s -- --daemon
    fi

    # Set current user as trusted user
    echo "trusted-users = root ${USER}" | sudo tee -a /etc/nix/nix.conf && sudo pkill nix-daemon

    # Load nix into THIS shell so the nix-channel calls below work. (Do not
    # source the zsh .zshrc from bash: it aborts under set -u on unbound
    # ZDOTDIR.) These profile scripts are what .zshrc itself sources.
    for nix_profile in \
      "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh" \
      "/nix/var/nix/profiles/default/etc/profile.d/nix.sh"; do
      if [[ -s "${nix_profile}" ]]; then
        # These vendor scripts are not 'set -u' clean (e.g. nix-daemon.sh reads
        # $ZSH_VERSION unguarded, which aborts on a fresh macOS), so disable
        # nounset just around the source.
        set +u
        # shellcheck source=/dev/null
        source "${nix_profile}"
        set -u
      fi
    done

    nix-channel --add https://nixos.org/channels/nixpkgs-unstable
  fi

  nix-channel --update
}

function install_cachix {
  if ! command -v cachix >/dev/null; then
    echo "nix install: setting up cachix..."
    nix-env -iA cachix -f https://cachix.org/api/v1/install
  fi
}

function install_devenv {
  if ! command -v devenv >/dev/null; then
    echo "nix install: setting up devenv..."
    nix-env -if https://github.com/cachix/devenv/tarball/latest
  fi
}

function main {
  install_nix
  install_cachix
  install_devenv
}

main
