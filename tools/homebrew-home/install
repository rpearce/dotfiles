#!/usr/bin/env bash

set -Eeuo pipefail

function install_or_update {
  if command -v brew >/dev/null; then
    brew update
  else
    export PATH="/opt/homebrew/bin:${PATH}"
    /bin/bash -c "$(curl -fsSL --proto '=https' --tlsv1.2 https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi
}

function run_bundle {
  brew bundle --file="./Brewfile" --cleanup --force --zap
}

function switch_to_homebrew_zsh {
  if [[ "$(uname)" == "Darwin" ]] && command -v zsh >/dev/null && [[ "$SHELL" != "/opt/homebrew/bin/zsh" ]]; then
    # Resolve the zsh path once and use it for the /etc/shells entry AND chsh, so
    # the registered shell always matches the one we switch to.
    local zsh_path
    zsh_path="$(command -v zsh)"
    grep -qxF "${zsh_path}" /etc/shells || echo "${zsh_path}" | sudo tee -a /etc/shells > /dev/null
    sudo chsh -s "${zsh_path}" "$USER"
  fi
}

function upgrade_and_cleanup {
  if command -v brew >/dev/null; then
    brew update && brew upgrade && brew cleanup
  fi
}

function main {
  install_or_update
  run_bundle
  switch_to_homebrew_zsh
  upgrade_and_cleanup
}

main
